{
  "name": "learn-noun-gender",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "data:extract": "node scripts/extract-ptbr-words.mjs && node scripts/extract-es-words.mjs && node scripts/extract-fr-words.mjs && node scripts/extract-it-words.mjs",
    "data:extract:es": "node scripts/extract-es-words.mjs",
    "data:extract:fr": "node scripts/extract-fr-words.mjs",
    "data:extract:it": "node scripts/extract-it-words.mjs",
    "data:extract:pt": "node scripts/extract-ptbr-words.mjs",
    "data:refresh:es": "node scripts/extract-es-words.mjs && node scripts/add-pattern-notes.mjs",
    "data:refresh:fr": "node scripts/extract-fr-words.mjs && node scripts/add-pattern-notes.mjs",
    "data:refresh:it": "node scripts/extract-it-words.mjs && node scripts/add-pattern-notes.mjs",
    "data:refresh:pt": "node scripts/extract-ptbr-words.mjs && node scripts/add-pattern-notes.mjs",
    "data:notes": "node scripts/add-pattern-notes.mjs",
    "data:all": "node scripts/extract-ptbr-words.mjs && node scripts/extract-es-words.mjs && node scripts/extract-fr-words.mjs && node scripts/extract-it-words.mjs && node scripts/add-pattern-notes.mjs"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ts-fsrs": "^5.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
